# Cau hinh clangd (IntelliSense) cho project STM32 Arduino.
# Tat canh bao gia "GCC version 6.3 or higher is required" (pp_hash_error):
# clangd phan tich bang clang nen macro __GNUC__ khac arm-none-eabi-gcc.
# Day chi anh huong editor, KHONG anh huong build (pio run) hay nap firmware.

Diagnostics:
  Suppress:
    - pp_hash_error

# (Tuy chon) Neu muon clangd dung dung toolchain ARM, bo comment va sua duong dan:
# CompileFlags:
#   Compiler: C:/Users/hohoa/.platformio/packages/toolchain-gccarmnoneeabi/bin/arm-none-eabi-gcc.exe

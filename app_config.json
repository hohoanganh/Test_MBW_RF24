{
  "device_id": "MBW_RF24_RS485",
  "console_baud": 115200,
  "test_groups": [
    {
      "key": "id",
      "name": "Xác thực thiết bị (ID)",
      "cmd": "id",
      "expect_contains": "MBW_RF24_RS485"
    },
    {
      "key": "dip",
      "name": "Đọc DIP switch (Network ID + Baudrate)",
      "cmd": "dip",
      "expect_contains": "NETID"
    },
    {
      "key": "flash",
      "name": "SPI Flash W25Q128 (đọc JEDEC ID)",
      "cmd": "flash",
      "expect_contains": "FLASH_ID=OK"
    },
    {
      "key": "rtc",
      "name": "RTC PCF85063 (đọc thời gian)",
      "cmd": "rtc",
      "expect_contains": "RTC:"
    },
    {
      "key": "rsl",
      "name": "RS485 loopback (cần nối tắt A-B)",
      "cmd": "rsl",
      "expect_contains": "RS485 LOOP OK",
      "manual_prereq": "Nối tắt chân A-B trên đầu nối RJ11/RS485 của board này. Không cần tắt bridge thủ công: lệnh 'rsl' chạy đồng bộ (chiếm trọn vòng lặp lúc gửi/nhận) nên không xung đột với bridge_process()."
    },
    {
      "key": "rf_id",
      "name": "Kiểm tra nRF24L01 có mặt",
      "cmd": "rf id",
      "expect_contains": "RF_ID=OK"
    }
  ]
}
